# ============================================================
# as-extension — Universal Payment Backend
# One backend. All extensions. Forever.
# ============================================================

# --- Razorpay (Required for India/UPI payments) ---
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# --- PayPal (Required for international payments) ---
PAYPAL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYPAL_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Security ---
LICENSE_SIGNING_SECRET=a-long-random-secret-string-change-this

# ============================================================
# EXTENSION PRICING — Add a new extension any time!
# Pattern: <EXT_KEY>_PRICE_INR and <EXT_KEY>_PRICE_USD
# EXT_KEY = extension id uppercased, hyphens → underscores
# e.g. "my-cool-tool" → MY_COOL_TOOL_PRICE_INR
# ============================================================

# Pixel Ruler
PIXEL_RULER_PRICE_INR=99
PIXEL_RULER_PRICE_USD=1.00
PIXEL_RULER_NAME=Pixel Ruler Premium

# Advanced Smart Capture
SMART_CAPTURE_PRICE_INR=249
SMART_CAPTURE_PRICE_USD=2.99
SMART_CAPTURE_NAME=Advanced Smart Capture Premium

# --- Add future extensions below (no code changes needed!) ---
# MY_NEW_TOOL_PRICE_INR=149
# MY_NEW_TOOL_PRICE_USD=1.99
# MY_NEW_TOOL_NAME=My New Tool Premium
